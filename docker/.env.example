# --- SQL Server ---
SA_PASSWORD=Your_Strong_Passw0rd!
SQL_DB=Rently
SQL_PORT=1433

# --- Backend (Rently.Api) ---
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080

# --- Autenticação JWT (placeholders — troque por segredo real fora do versionamento) ---
JWT_ISSUER=rently-api
JWT_AUDIENCE=rently-clients
JWT_SIGNING_KEY=change-me-please-use-a-32-plus-char-secret

# --- Frontend (Rently.Web / Nginx) ---
WEB_PORT=4200
